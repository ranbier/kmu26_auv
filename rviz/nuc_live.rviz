Panels:
  - Class: rviz_common/Displays
    Help Height: 84
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /TF1
        - /TF1/Frames1
        - /RobotModel1
        - /DVL Odom1
        - /ROVIO Odom1
        - /filtered Odometry1
